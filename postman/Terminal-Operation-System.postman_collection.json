            ],
            "url": "{{gateway_url}}/yard/moves/{{yard_move_id}}/reschedule",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduledAtUtc\": \"{{future_scheduled_at_utc}}\"\n}"
            }
