        {
          "name": "5 - Reschedule Move",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const future = new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString();",
                  "pm.environment.set('future_scheduled_at_utc', future);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns 204', () => pm.response.to.have.status(204));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
