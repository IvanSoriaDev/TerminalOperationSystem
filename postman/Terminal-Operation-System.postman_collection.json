{
  "info": {
    "name": "Terminal Operation System",
    "description": "End-to-end collection for the Terminal Operation System microservices. Run the auth requests first, then the protected service folders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1 - Get JWT Token - Operator",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{gateway_url}}/auth/token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"terminal-web-client\",\n  \"clientSecret\": \"change-me-in-production\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns 200', () => pm.response.to.have.status(200));",
                  "const response = pm.response.json();",
                  "pm.expect(response.accessToken).to.be.a('string').and.not.empty;",
                  "pm.environment.set('access_token', response.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "2 - Get JWT Token - Readonly",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{gateway_url}}/auth/token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"yard-readonly-client\",\n  \"clientSecret\": \"readonly-secret\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns 200', () => pm.response.to.have.status(200));",
                  "const response = pm.response.json();",
                  "pm.expect(response.accessToken).to.be.a('string').and.not.empty;",
                  "pm.environment.set('readonly_token', response.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3 - Invalid Credentials Returns 401",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{gateway_url}}/auth/token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"unknown-client\",\n  \"clientSecret\": \"wrong-secret\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns 401', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
